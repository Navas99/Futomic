@model IEnumerable<Futomic.View_Models.RankingRowViewModel>

@{
    ViewData["Title"] = "Ranking";
}

<div class="container mt-4">

    <div class="card">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="fw-bold mb-0">Ranking de Equipos</h2>

            <form method="get" class="d-flex gap-2">
                <select name="level" class="form-select">
                    <option value="">Todos los niveles</option>
                    @foreach (LevelTeam lvl in ViewBag.Levels)
                    {
                        <option value="@lvl"
                                selected="@(ViewBag.SelectedLevel != null && (LevelTeam)ViewBag.SelectedLevel == lvl)">
                            @lvl
                        </option>
                    }
                </select>
                <button class="btn btn-primary">
                    Filtrar
                </button>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Equipo</th>
                        <th>Nivel</th>
                        <th>Puntos</th>
                        <th>Último</th>
                        <th>Racha</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end">Acciones</th>
                        }
                    </tr>
                </thead>

                <tbody>
                    @{
                        int pos = 1;
                    }

                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="fw-bold">@pos</td>

                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(r.TeamLogoUrl))
                                    {
                                        <img src="@r.TeamLogoUrl"
                                             alt="@r.TeamName"
                                             width="28"
                                             height="28"
                                             class="rounded-circle" />
                                    }
                                    <span class="fw-semibold">@r.TeamName</span>
                                </div>
                            </td>

                            <td>
                                <span class="badge bg-success">
                                    @r.Level
                                </span>
                            </td>

                            <td class="fw-bold">@r.Points</td>
                            <td>@r.LastMatchResult</td>
                            <td>
                                @string.Join(" ", r.CurrentStreak.ToCharArray())
                            </td>

                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a asp-action="RegisterMatch"
                                       asp-route-teamId="@r.TeamId"
                                       class="btn btn-sm btn-danger">
                                        Registrar partido
                                    </a>
                                </td>
                            }
                        </tr>
                        pos++;
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>












