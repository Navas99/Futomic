@model Futomic.View_Models.ReservationCreateViewModel

<div class="container mt-4">
    <div class="card shadow-sm p-4 mx-auto" style="max-width: 500px;">
        <h2 class="fw-bold mb-4 text-center">Confirmar reserva</h2>

        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="FieldId" />
            <input type="hidden" asp-for="DateReservation" />

            <!-- FECHA -->
            <div class="mb-3">
                <label class="form-label fw-bold">Fecha y hora</label>
                <div class="p-2 bg-light border rounded">
                    @Model.DateReservation.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <!-- DURACIÓN -->
            <div class="mb-3">
                <label asp-for="Duration" class="form-label">Duración</label>
                <select asp-for="Duration" class="form-select">
                    <option value="60">60 minutos</option>
                    <option value="120">120 minutos</option>
                    <option value="240">240 minutos</option>
                </select>
            </div>

            <!-- MÉTODO DE PAGO -->
            <div class="mb-4">
                <label asp-for="Paymen" class="form-label">Método de pago</label>
                <select asp-for="Paymen" class="form-select">
                    <option value="0">Efectivo</option>
                    <option value="1">Tarjeta</option>
                    <option value="2">Bizum</option>
                </select>
            </div>

            <button type="submit" class="btn btn-success w-100">
                Confirmar reserva
            </button>
        </form>
    </div>
</div>
