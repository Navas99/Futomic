@model Futomic.View_Models.MyTeamViewModel

@{
    ViewData["Title"] = "Mi Equipo";

    var logo = string.IsNullOrEmpty(Model.LogoUrl)
        ? "/images/default-team.png"
        : Model.LogoUrl;
}

<div class="container mt-4">

    <h2 class="mb-4 fw-bold">Mi Equipo</h2>

    <!-- INFO EQUIPO -->
    <div class="card shadow-sm mb-4 p-3">
        <div class="d-flex flex-column flex-md-row align-items-center gap-3">
            <img src="@logo"
                 width="100"
                 height="100"
                 class="rounded border border-2"
                 style="object-fit:cover;"
                 alt="Logo del equipo" />

            <div class="text-center text-md-start">
                <h3 class="fw-bold mb-1">@Model.Name</h3>

                <span class="badge bg-success me-2">@Model.Level</span>

                <p class="text-muted mb-0">Fundado el @Model.CreationDate.ToShortDateString()</p>
            </div>
        </div>
    </div>

    <!-- JUGADORES -->
    <h4 class="mb-3">Jugadores</h4>

    @if (!Model.Players.Any())
    {
        <p class="text-muted">Este equipo aún no tiene jugadores registrados.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-3 mb-4">
            @foreach (var p in Model.Players)
            {
                <div class="col">
                    <div class="card h-100 text-center shadow-sm p-2">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@p.Name</h5>
                            <p class="text-muted mb-0">@p.Position</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- PARTIDOS -->
    <h4 class="mb-3">Últimos partidos</h4>

    @if (!Model.Matches.Any())
    {
        <p class="text-muted">Este equipo aún no ha jugado partidos.</p>
    }
    else
    {
        <div class="card shadow-sm mb-4 p-3">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Rival</th>
                            <th>Resultado</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody class="table-light">
                        @foreach (var m in Model.Matches)
                        {
                            <tr>
                                <td>@m.Rival</td>
                                <td>
                                    @if (m.Result.Contains("Victoria"))
                                    {
                                        <span class="badge bg-success">@m.Result</span>
                                    }
                                    else if (m.Result.Contains("Derrota"))
                                    {
                                        <span class="badge bg-danger">@m.Result</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@m.Result</span>
                                    }
                                </td>
                                <td>@m.PlayedAt.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }


    <!-- ESTADÍSTICAS -->
    <h4 class="mb-3">Estadísticas</h4>

    <div class="row g-3 text-center mb-5">
        <div class="col-6 col-md-2">
            <div class="card shadow-sm p-2">
                <strong>@Model.Stats.MatchesPlayed</strong><br />
                <span>Partidos</span>
            </div>
        </div>

        <div class="col-6 col-md-2">
            <div class="card shadow-sm p-2">
                <strong>@Model.Stats.Wins</strong><br />
                <span>Victorias</span>
            </div>
        </div>

        <div class="col-6 col-md-2">
            <div class="card shadow-sm p-2">
                <strong>@Model.Stats.Losses</strong><br />
                <span>Derrotas</span>
            </div>
        </div>

        <div class="col-6 col-md-2">
            <div class="card shadow-sm p-2">
                <strong>@Model.Stats.Points</strong><br />
                <span>Puntos</span>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card shadow-sm p-2">
                <strong>@Model.Stats.Form</strong><br />
                <span class="text-muted">Racha (últimos 5)</span>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-secondary">
        ← Volver a equipos
    </a>
</div>


