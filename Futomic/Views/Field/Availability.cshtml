@model Futomic.View_Models.FieldAvailabilityViewModel

<div class="container mt-4">

    <!-- INFO CAMPO -->
    <div class="card shadow-sm p-3 mb-4">
        <h2 class="fw-bold mb-1">@Model.FieldName</h2>
        <p class="text-muted mb-0">@Model.Location</p>
    </div>

    <!-- SELECCIÓN DE FECHA -->
    <form method="get" class="mb-4 d-flex align-items-center gap-2 flex-wrap">
        <input type="hidden" name="id" value="@Model.FieldId" />
        <input type="date"
               name="date"
               min="@DateTime.Today.ToString("yyyy-MM-dd")"
               value="@Model.SelectedDate.ToString("yyyy-MM-dd")"
               class="form-control w-auto" />
        <button class="btn btn-primary">Ver disponibilidad</button>
    </form>

    <!-- TABLA DE HORARIOS -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered text-center align-middle">
            <thead class="table-light">
                <tr>
                    <th>Hora</th>
                    <th>Estado</th>
                    <th>Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in Model.TimeSlots)
                {
                    <tr>
                        <td class="fw-bold">
                            @slot.Start.ToString(@"HH\:mm") - @slot.End.ToString(@"HH\:mm")
                        </td>
                        <td>
                            @if (slot.IsAvailable)
                            {
                                <span class="badge bg-success">Libre</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ocupado</span>
                            }
                        </td>
                        <td>
                            @if (slot.IsAvailable)
                            {
                                <a class="btn btn-sm btn-success"
                                   asp-controller="Reservation"
                                   asp-action="Create"
                                   asp-route-fieldId="@Model.FieldId"
                                   asp-route-date="@slot.Start.ToString("yyyy-MM-ddTHH:mm:ss")">
                                    Reservar
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-secondary" disabled>Reservar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


