@model IEnumerable<Futomic.View_Models.MyReservationsViewModel>

<div class="container mt-4">
    <h2 class="mb-4 fw-bold">Mis Reservas</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No tienes reservas activas.
        </div>
    }
    else
    {
        <div class="card shadow-sm p-3">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Campo</th>
                            <th>Ubicación</th>
                            <th>Equipo</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Duración</th>
                            <th>Precio</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="table-light">
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.FieldName</td>
                                <td>@r.Location</td>
                                <td>@r.TeamName</td>
                                <td>@r.DateReservation.ToString("dd/MM/yyyy")</td>
                                <td>@r.DateReservation.ToString("HH:mm")</td>
                                <td>@r.Duration min</td>
                                <td>@r.Price €</td>
                                <td>
                                    @switch (r.State)
                                    {
                                        case EstadoReserva.Pendiente:
                                            <span class="badge bg-warning text-dark">Pendiente</span>
                                            break;
                                        case EstadoReserva.Confirmada:
                                            <span class="badge bg-success">Confirmada</span>
                                            break;
                                        case EstadoReserva.Cancelada:
                                            <span class="badge bg-danger">Cancelada</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-primary"
                                       asp-action="DownloadPdf"
                                       asp-route-id="@r.ReservationId">
                                        PDF
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
